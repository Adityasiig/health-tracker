# Supabase — server-side keys (Settings → API)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_ANON_KEY=sb_publishable_...

# Same URL + anon key exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Groq — AI Coach (https://console.groq.com)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# USDA FoodData Central (https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=...

# Natural-language food parsing: handled by Groq (reuses GROQ_API_KEY above).
# /api/food/nlp parses "1 katori dal", "2 rotis", "30g paneer" via llama-3.3-70b
# and looks the result up in the IFCT 2017 seed. No extra account needed.
